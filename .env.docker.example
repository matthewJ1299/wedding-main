# Copy to .env next to docker-compose.yml and adjust values.
#
# URLs used by the browser must match what you expose publicly.
# For local docker-compose defaults, leave as http://localhost:* .

FRONTEND_URL=http://localhost:8080
ORIGIN_URL=http://localhost:8080
REACT_APP_API_URL=http://localhost:3001
REACT_APP_SITE_URL=http://localhost:8080

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

ADMIN_EMAIL=you@example.com
JWT_SECRET=generate-a-long-random-string
SESSION_SECRET=generate-another-long-random-string
