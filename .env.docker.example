# Optional: copy to `.env` beside docker-compose.yml (Coolify also injects these via UI).
#
# Defaults in docker-compose.yml already use production URLs (matthewandsydney.co.za).
# Set secrets and SMTP here or in Coolify; only define what you need to override.

# --- Public URLs (defaults match compose; uncomment to override) ---
# FRONTEND_URL=https://matthewandsydney.co.za
# ORIGIN_URL=https://matthewandsydney.co.za
# REACT_APP_API_URL=https://api.matthewandsydney.co.za
# REACT_APP_SITE_URL=https://matthewandsydney.co.za

# --- SMTP ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- App secrets (required in production) ---
ADMIN_EMAIL=you@example.com
JWT_SECRET=generate-a-long-random-string
SESSION_SECRET=generate-another-long-random-string

# Local machine with published ports: use docker-compose.local.yml (it sets localhost URLs).
# docker compose -f docker-compose.yml -f docker-compose.local.yml up --build
